<UserControl x:Class="SACA.WindowsApp.Controls.VoiceRecorderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Margin="0,0,0,25">
        <TextBlock Text="Voice Recording" Style="{StaticResource SectionLabelTextStyle}"/>

        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
            <Button x:Name="RecordButton"
                    Width="170"
                    Height="42"
                    PreviewMouseLeftButtonDown="RecordButton_PreviewMouseLeftButtonDown"
                    PreviewMouseLeftButtonUp="RecordButton_PreviewMouseLeftButtonUp"
                    MouseLeave="RecordButton_MouseLeave">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="&#xE720;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="16"
                               Foreground="White"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Hold to record"
                               Foreground="White"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <TextBlock x:Name="RecordingStatusTextBlock"
                       Text="No recording"
                       Foreground="{StaticResource MutedTextBrush}"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"/>
        </StackPanel>
    </StackPanel>
</UserControl>
