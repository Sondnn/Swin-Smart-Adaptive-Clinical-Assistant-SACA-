<UserControl x:Class="SACA.WindowsApp.Pages.SymptomsHistoryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:SACA.WindowsApp.Controls"
             xmlns:services="clr-namespace:SACA.WindowsApp.Services">

    <Grid Background="{StaticResource AppBackgroundBrush}" Margin="40">
        <StackPanel Width="560" HorizontalAlignment="Center" VerticalAlignment="Center">

            <TextBlock Text="{services:Loc had_before_title}"
                       Style="{StaticResource PageTitleTextStyle}"
                       FontSize="30"
                       TextWrapping="Wrap"
                       Margin="0,0,0,30"/>

            <StackPanel Margin="0,0,0,35">
                <RadioButton x:Name="YesRadioButton"
                             Content="{services:Loc yes}"
                             GroupName="SymptomsHistory"
                             FontSize="18"
                             Margin="0,0,0,16"/>
                <RadioButton x:Name="NoRadioButton"
                             Content="{services:Loc no}"
                             GroupName="SymptomsHistory"
                             FontSize="18"
                             Margin="0,0,0,16"/>
                <RadioButton x:Name="UnknownRadioButton"
                             Content="{services:Loc unknown}"
                             GroupName="SymptomsHistory"
                             FontSize="18"/>
            </StackPanel>

            <controls:VoiceRecorderControl x:Name="VoiceRecorder"
                                           QuestionId="7"
                                           Label="{services:Loc voice_before}"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{services:Loc back}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="120"
                        Height="40"
                        Margin="0,0,10,0"
                        Click="Back_Click"/>

                <Button Content="{services:Loc continue}"
                        Width="140"
                        Height="40"
                        Click="Continue_Click"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</UserControl>
