<UserControl x:Class="SACA.WindowsApp.Pages.PatientInfoPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:SACA.WindowsApp.Controls">

    <Grid Background="{StaticResource AppBackgroundBrush}" Margin="40">
        <StackPanel Width="520" HorizontalAlignment="Center" VerticalAlignment="Center">

            <TextBlock Text="Triage Assessment"
                       Foreground="{StaticResource PrimaryTextBrush}"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Margin="0,0,0,30"/>

            <TextBlock Text="Patient Details"
                       Style="{StaticResource PageTitleTextStyle}"
                       FontSize="30"
                       Margin="0,0,0,25"
                       TextAlignment="Center"/>

            <TextBlock Text="Gender" Style="{StaticResource SectionLabelTextStyle}"/>
            <ComboBox x:Name="GenderComboBox"
                      Height="40"
                      Margin="0,5,0,20"
                      SelectionChanged="GenderComboBox_SelectionChanged">
                <ComboBoxItem Content="Male"/>
                <ComboBoxItem Content="Female"/>
                <ComboBoxItem Content="Unknown / Prefer not to say"/>
            </ComboBox>

            <TextBlock Text="Your Age" Style="{StaticResource SectionLabelTextStyle}"/>
            <ComboBox x:Name="AgeComboBox"
                      Height="40"
                      Margin="0,5,0,30">
                <ComboBoxItem Content="65 years old or younger"/>
                <ComboBoxItem Content="Older than 65"/>
            </ComboBox>

            <controls:VoiceRecorderControl x:Name="GenderVoiceRecorder"
                                           QuestionId="1"
                                           Label="Voice answer for gender"/>

            <controls:VoiceRecorderControl x:Name="AgeVoiceRecorder"
                                           QuestionId="2"
                                           Label="Voice answer for age"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Back"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="120"
                        Height="40"
                        Margin="0,0,10,0"
                        Click="Back_Click"/>

                <Button Content="Continue"
                        Width="140"
                        Height="40"
                        Click="Continue_Click"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</UserControl>
