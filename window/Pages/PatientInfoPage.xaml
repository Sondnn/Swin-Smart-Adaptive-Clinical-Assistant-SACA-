<UserControl x:Class="SACA.WindowsApp.Pages.PatientInfoPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource AppBackgroundBrush}" Margin="40">
        <StackPanel Width="520" HorizontalAlignment="Center" VerticalAlignment="Center">

            <TextBlock Text="Triage Assessment"
                       Foreground="{StaticResource PrimaryTextBrush}"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Margin="0,0,0,30"/>

            <TextBlock Text="Patient Details"
                       Style="{StaticResource PageTitleTextStyle}"
                       FontSize="30"
                       Margin="0,0,0,25"
                       TextAlignment="Center"/>

            <TextBlock Text="Gender" Style="{StaticResource SectionLabelTextStyle}"/>
            <ComboBox x:Name="GenderComboBox"
                      Height="40"
                      Margin="0,5,0,20"
                      SelectionChanged="GenderComboBox_SelectionChanged">
                <ComboBoxItem Content="Male"/>
                <ComboBoxItem Content="Female"/>
            </ComboBox>

            <TextBlock x:Name="PregnancyLabel"
                       Text="Pregnancy Status"
                       Style="{StaticResource SectionLabelTextStyle}"
                       Visibility="Collapsed"/>

            <ComboBox x:Name="PregnancyComboBox"
                      Height="40"
                      Margin="0,5,0,20"
                      Visibility="Collapsed">
                <ComboBoxItem Content="Pregnant"/>
                <ComboBoxItem Content="Not Pregnant"/>
                <ComboBoxItem Content="Unknown"/>
            </ComboBox>

            <TextBlock Text="Your Age" Style="{StaticResource SectionLabelTextStyle}"/>
            <ComboBox x:Name="AgeComboBox"
                      Height="40"
                      Margin="0,5,0,30">
                <ComboBoxItem Content="65 years old or younger"/>
                <ComboBoxItem Content="Older than 65"/>
            </ComboBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Back"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="120"
                        Height="40"
                        Margin="0,0,10,0"
                        Click="Back_Click"/>

                <Button Content="Continue"
                        Width="140"
                        Height="40"
                        Click="Continue_Click"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</UserControl>
