<UserControl x:Class="SACA.WindowsApp.Pages.SplashPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="clr-namespace:SACA.WindowsApp.Services">

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="420">

            <TextBlock Text="{services:Loc app_name}"
                       FontSize="34"
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryTextBrush}"
                       TextAlignment="Center"
                       Margin="0,0,0,20"/>

            <TextBlock Text="{services:Loc welcome}"
                       FontSize="20"
                       Foreground="{StaticResource BodyTextBrush}"
                       TextAlignment="Center"
                       Margin="0,0,0,60"/>

            <Button Content="{services:Loc english}"
                    Height="45"
                    Margin="0,0,0,15"
                    Click="English_Click"/>

            <Button Content="{services:Loc walmajarri}"
                    Height="45"
                    Click="Walmajarri_Click"/>

        </StackPanel>
    </Grid>
</UserControl>
