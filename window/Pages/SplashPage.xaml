<UserControl x:Class="SACA.WindowsApp.Pages.SplashPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#0F4D45">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="420">

            <TextBlock Text="Smart Adaptive&#x0a;Clinical Assistant"
                       FontSize="34"
                       FontWeight="Bold"
                       Foreground="White"
                       TextAlignment="Center"
                       Margin="0,0,0,20"/>

            <TextBlock Text="Welcome!"
                       FontSize="20"
                       Foreground="White"
                       TextAlignment="Center"
                       Margin="0,0,0,60"/>

            <Button Content="English"
                    Height="45"
                    Margin="0,0,0,15"
                    Click="English_Click"/>

            <Button Content="Walmajarri"
                    Height="45"
                    Click="Walmajarri_Click"/>

        </StackPanel>
    </Grid>
</UserControl>