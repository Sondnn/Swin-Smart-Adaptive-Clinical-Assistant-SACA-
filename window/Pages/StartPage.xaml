<UserControl x:Class="SACA.WindowsApp.Pages.StartPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Image Source="pack://application:,,,/Assets/Images/Doctors-pana.png"
               Stretch="UniformToFill"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Top"
               Opacity="0.35"
               IsHitTestVisible="False"/>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="520">


            <TextBlock Text="Triage Assessment"
                       Style="{StaticResource PageTitleTextStyle}"
                       FontSize="32"
                       Margin="0,0,0,15"/>

            <TextBlock Text="This assessment will help you check your symptoms quickly and understand what to do next."
                       FontSize="18"
                       Foreground="{StaticResource BodyTextBrush}"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Margin="0,0,0,40"/>

            <Button Content="Get Started"
                    Width="220"
                    Height="45"
                    Click="GetStarted_Click"/>

        </StackPanel>
    </Grid>
</UserControl>
