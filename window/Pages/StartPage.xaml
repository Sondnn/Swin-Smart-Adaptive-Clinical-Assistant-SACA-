<UserControl x:Class="SACA.WindowsApp.Pages.StartPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#FFF8F1">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="520">

            <TextBlock Text="Clinical Assistant"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Margin="0,0,0,30"/>

            <TextBlock Text="Triage Assessment"
                       FontSize="32"
                       FontWeight="Bold"
                       TextAlignment="Center"
                       Margin="0,0,0,15"/>

            <TextBlock Text="This assessment will help you check your symptoms quickly and understand what to do next."
                       FontSize="18"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Margin="0,0,0,40"/>

            <Button Content="Get Started"
                    Width="220"
                    Height="45"
                    Click="GetStarted_Click"/>

        </StackPanel>
    </Grid>
</UserControl>