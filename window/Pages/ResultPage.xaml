<UserControl x:Class="SACA.WindowsApp.Pages.ResultPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#FFF8F1" Margin="40">
        <Border Background="White"
                Padding="35"
                Width="600"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                CornerRadius="14">

            <StackPanel>
                <TextBlock Text="Triage Result"
                           FontSize="32"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           Margin="0,0,0,25"/>

                <TextBlock x:Name="SeverityTextBlock"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,0,0,15"/>

                <TextBlock x:Name="RecommendationTextBlock"
                           FontSize="17"
                           TextWrapping="Wrap"
                           Margin="0,0,0,25"/>

                <TextBlock Text="Symptom Summary"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <TextBlock x:Name="SummaryTextBlock"
                           FontSize="16"
                           TextWrapping="Wrap"
                           Margin="0,0,0,30"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Start Again"
                            Width="140"
                            Height="40"
                            Margin="0,0,10,0"
                            Click="StartAgain_Click"/>

                    <Button Content="OK"
                            Width="100"
                            Height="40"
                            Click="Ok_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>