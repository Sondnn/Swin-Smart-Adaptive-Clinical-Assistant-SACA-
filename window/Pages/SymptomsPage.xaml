<UserControl x:Class="SACA.WindowsApp.Pages.SymptomsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:SACA.WindowsApp.Controls"
             xmlns:services="clr-namespace:SACA.WindowsApp.Services">

    <UserControl.Resources>
        <Style x:Key="SymptomCardCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource BodyTextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Card"
                                Background="{StaticResource InputBackgroundBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="2"
                                CornerRadius="8"
                                Padding="12"
                                Width="166"
                                MinHeight="104">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Card" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="{StaticResource SelectedBackgroundBrush}"/>
                                <Setter TargetName="Card" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}" Margin="32,24">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
        <StackPanel Width="740"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <TextBlock Text="{services:Loc triage_assessment}"
                       Foreground="{StaticResource PrimaryTextBrush}"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,4">
                <TextBlock Text="{services:Loc symptoms_title}"
                           Style="{StaticResource PageTitleTextStyle}"
                           FontSize="28"
                           MaxWidth="620"
                           TextWrapping="Wrap"
                           TextTrimming="None"
                           TextAlignment="Center"
                           VerticalAlignment="Center"/>
                <controls:SpeakerButtonControl TextKey="speak_symptoms"/>
            </StackPanel>

            <WrapPanel Margin="0,2,0,14" HorizontalAlignment="Center">
                <CheckBox Tag="Fever" Style="{StaticResource SymptomCardCheckBoxStyle}">
                    <StackPanel>
                        <Image Source="/Assets/Icons/thermometer 1.png" Width="44" Height="44" Stretch="Uniform" Margin="0,0,0,6"/>
                        <TextBlock Text="{services:Loc symptom_fever}" TextAlignment="Center" TextWrapping="Wrap" FontSize="15"/>
                    </StackPanel>
                </CheckBox>
                <CheckBox Tag="Diarrhoea" Style="{StaticResource SymptomCardCheckBoxStyle}">
                    <StackPanel>
                        <Image Source="/Assets/Icons/stomach-flu 1.png" Width="44" Height="44" Stretch="Uniform" Margin="0,0,0,6"/>
                        <TextBlock Text="{services:Loc symptom_diarrhea}" TextAlignment="Center" TextWrapping="Wrap" FontSize="15"/>
                    </StackPanel>
                </CheckBox>
                <CheckBox Tag="Cough" Style="{StaticResource SymptomCardCheckBoxStyle}">
                    <StackPanel>
                        <Image Source="/Assets/Icons/sneezing 1.png" Width="44" Height="44" Stretch="Uniform" Margin="0,0,0,6"/>
                        <TextBlock Text="{services:Loc symptom_cough}" TextAlignment="Center" TextWrapping="Wrap" FontSize="15"/>
                    </StackPanel>
                </CheckBox>
                <CheckBox Tag="Vomiting" Style="{StaticResource SymptomCardCheckBoxStyle}">
                    <StackPanel>
                        <Image Source="/Assets/Icons/vomiting 1.png" Width="44" Height="44" Stretch="Uniform" Margin="0,0,0,6"/>
                        <TextBlock Text="{services:Loc symptom_vomiting}" TextAlignment="Center" TextWrapping="Wrap" FontSize="15"/>
                    </StackPanel>
                </CheckBox>
                <CheckBox Tag="Dizziness" Style="{StaticResource SymptomCardCheckBoxStyle}">
                    <StackPanel>
                        <Image Source="/Assets/Icons/dizzy (1) 1.png" Width="44" Height="44" Stretch="Uniform" Margin="0,0,0,6"/>
                        <TextBlock Text="{services:Loc symptom_dizziness}" TextAlignment="Center" TextWrapping="Wrap" FontSize="15"/>
                    </StackPanel>
                </CheckBox>
                <CheckBox Tag="Runny Nose" Style="{StaticResource SymptomCardCheckBoxStyle}">
                    <StackPanel>
                        <Image Source="/Assets/Icons/runny-nose 1.png" Width="44" Height="44" Stretch="Uniform" Margin="0,0,0,6"/>
                        <TextBlock Text="{services:Loc symptom_runny_nose}" TextAlignment="Center" TextWrapping="Wrap" FontSize="15"/>
                    </StackPanel>
                </CheckBox>
                <CheckBox Tag="Eye Pain" Style="{StaticResource SymptomCardCheckBoxStyle}">
                    <StackPanel>
                        <Image Source="/Assets/Icons/eye 1.png" Width="44" Height="44" Stretch="Uniform" Margin="0,0,0,6"/>
                        <TextBlock Text="{services:Loc symptom_eye_pain}" TextAlignment="Center" TextWrapping="Wrap" FontSize="15"/>
                    </StackPanel>
                </CheckBox>
                <CheckBox Tag="Sore Throat" Style="{StaticResource SymptomCardCheckBoxStyle}">
                    <StackPanel>
                        <Image Source="/Assets/Icons/sore-throat (1) 1.png" Width="44" Height="44" Stretch="Uniform" Margin="0,0,0,6"/>
                        <TextBlock Text="{services:Loc symptom_sore_throat}" TextAlignment="Center" TextWrapping="Wrap" FontSize="15"/>
                    </StackPanel>
                </CheckBox>
                <CheckBox Tag="Headache" Style="{StaticResource SymptomCardCheckBoxStyle}">
                    <StackPanel>
                        <Image Source="/Assets/Icons/headache (1) 1.png" Width="44" Height="44" Stretch="Uniform" Margin="0,0,0,6"/>
                        <TextBlock Text="{services:Loc symptom_headache}" TextAlignment="Center" TextWrapping="Wrap" FontSize="15"/>
                    </StackPanel>
                </CheckBox>
                <CheckBox Tag="Joint Pain" Style="{StaticResource SymptomCardCheckBoxStyle}">
                    <StackPanel>
                        <Image Source="/Assets/Icons/pain 1.png" Width="44" Height="44" Stretch="Uniform" Margin="0,0,0,6"/>
                        <TextBlock Text="{services:Loc symptom_joint_pain}" TextAlignment="Center" TextWrapping="Wrap" FontSize="15"/>
                    </StackPanel>
                </CheckBox>
                <CheckBox Tag="Abdominal Pain" Style="{StaticResource SymptomCardCheckBoxStyle}">
                    <StackPanel>
                        <Image Source="/Assets/Icons/constipation 1.png" Width="44" Height="44" Stretch="Uniform" Margin="0,0,0,6"/>
                        <TextBlock Text="{services:Loc symptom_abdominal_pain}" TextAlignment="Center" TextWrapping="Wrap" FontSize="15"/>
                    </StackPanel>
                </CheckBox>
                <CheckBox Tag="Body Aches" Style="{StaticResource SymptomCardCheckBoxStyle}">
                    <StackPanel>
                        <Image Source="/Assets/Icons/back 1.png" Width="44" Height="44" Stretch="Uniform" Margin="0,0,0,6"/>
                        <TextBlock Text="{services:Loc symptom_body_pain}" TextAlignment="Center" TextWrapping="Wrap" FontSize="15"/>
                    </StackPanel>
                </CheckBox>
            </WrapPanel>

            <controls:VoiceRecorderControl x:Name="SymptomsVoiceRecorder"
                                           QuestionId="3"
                                           Label="{services:Loc voice_symptoms}"/>

            <Border x:Name="TranscriptBorder"
                    Background="{StaticResource SelectedBackgroundBrush}"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="2"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,0,0,14"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="{services:Loc recorded_symptoms}"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               FontWeight="Bold"
                               FontSize="16"
                               Margin="0,0,0,6"/>
                    <TextBlock x:Name="TranscriptTextBlock"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               FontSize="17"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,0">
                <Button Content="{services:Loc back}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="120"
                        Height="40"
                        Margin="0,0,10,0"
                        Click="Back_Click"/>

            <Button Content="{services:Loc continue}"
                    Width="140"
                    Height="40"
                    Click="Continue_Click"/>
            </StackPanel>

        </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
