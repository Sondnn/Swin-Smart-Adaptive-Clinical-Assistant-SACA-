<UserControl x:Class="SACA.WindowsApp.Pages.SymptomsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource AppBackgroundBrush}" Margin="40">
        <StackPanel Width="650" HorizontalAlignment="Center">

            <TextBlock Text="Triage Assessment"
                       Foreground="{StaticResource PrimaryTextBrush}"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Margin="0,0,0,25"/>

            <TextBlock Text="Select Any Symptoms"
                       Style="{StaticResource PageTitleTextStyle}"
                       FontSize="30"
                       Margin="0,0,0,20"/>

            <WrapPanel Margin="0,0,0,25">
                <CheckBox Content="Fever" Margin="10"/>
                <CheckBox Content="Diarrhea" Margin="10"/>
                <CheckBox Content="Cough" Margin="10"/>
                <CheckBox Content="Vomiting" Margin="10"/>
                <CheckBox Content="Dizziness" Margin="10"/>
                <CheckBox Content="Runny Nose" Margin="10"/>
                <CheckBox Content="Eye Pain" Margin="10"/>
                <CheckBox Content="Sore Throat" Margin="10"/>
                <CheckBox Content="Headache" Margin="10"/>
                <CheckBox Content="Joint Pain" Margin="10"/>
                <CheckBox Content="Abdominal Pain" Margin="10"/>
                <CheckBox Content="Body Pain" Margin="10"/>
            </WrapPanel>

            <TextBlock Text="Describe Symptoms" Style="{StaticResource SectionLabelTextStyle}"/>
            <TextBox x:Name="DescriptionTextBox"
                     Height="90"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     Margin="0,5,0,20"/>

            <TextBlock Text="Voice Recording" Style="{StaticResource SectionLabelTextStyle}"/>
            <StackPanel Orientation="Horizontal" Margin="0,5,0,20">
                <Button x:Name="RecordButton"
                        Width="170"
                        Height="42"
                        PreviewMouseLeftButtonDown="RecordButton_PreviewMouseLeftButtonDown"
                        PreviewMouseLeftButtonUp="RecordButton_PreviewMouseLeftButtonUp"
                        MouseLeave="RecordButton_MouseLeave">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE720;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="16"
                                   Foreground="White"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Hold to record"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <TextBlock x:Name="RecordingStatusTextBlock"
                           Text="No recording"
                           Foreground="{StaticResource MutedTextBrush}"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"/>
            </StackPanel>

            <TextBlock Text="Severity" Style="{StaticResource SectionLabelTextStyle}"/>
            <ComboBox x:Name="SeverityComboBox" Height="40" Margin="0,5,0,25">
                <ComboBoxItem Content="Mild"/>
                <ComboBoxItem Content="Low"/>
                <ComboBoxItem Content="Moderate"/>
                <ComboBoxItem Content="High"/>
                <ComboBoxItem Content="Severe"/>
            </ComboBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Back"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="120"
                        Height="40"
                        Margin="0,0,10,0"
                        Click="Back_Click"/>

                <Button Content="Continue"
                        Width="140"
                        Height="40"
                        Click="Continue_Click"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</UserControl>
