<UserControl x:Class="SACA.WindowsApp.Pages.SymptomsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:SACA.WindowsApp.Controls">

    <Grid Background="{StaticResource AppBackgroundBrush}" Margin="40">
        <StackPanel Width="650" HorizontalAlignment="Center">

            <TextBlock Text="Triage Assessment"
                       Foreground="{StaticResource PrimaryTextBrush}"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Margin="0,0,0,25"/>

            <TextBlock Text="Select Any Symptoms"
                       Style="{StaticResource PageTitleTextStyle}"
                       FontSize="30"
                       Margin="0,0,0,20"/>

            <WrapPanel Margin="0,0,0,25">
                <CheckBox Content="Fever" Margin="10"/>
                <CheckBox Content="Diarrhea" Margin="10"/>
                <CheckBox Content="Cough" Margin="10"/>
                <CheckBox Content="Vomiting" Margin="10"/>
                <CheckBox Content="Dizziness" Margin="10"/>
                <CheckBox Content="Runny Nose" Margin="10"/>
                <CheckBox Content="Eye Pain" Margin="10"/>
                <CheckBox Content="Sore Throat" Margin="10"/>
                <CheckBox Content="Headache" Margin="10"/>
                <CheckBox Content="Joint Pain" Margin="10"/>
                <CheckBox Content="Abdominal Pain" Margin="10"/>
                <CheckBox Content="Body Pain" Margin="10"/>
            </WrapPanel>

            <controls:VoiceRecorderControl x:Name="SymptomsVoiceRecorder"
                                           QuestionId="3"
                                           Label="Voice answer for symptoms"/>

            <Border x:Name="TranscriptBorder"
                    Background="{StaticResource SelectedBackgroundBrush}"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="2"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,0,0,20"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="Recorded symptoms:"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               FontWeight="Bold"
                               FontSize="16"
                               Margin="0,0,0,6"/>
                    <TextBlock x:Name="TranscriptTextBlock"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               FontSize="17"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <TextBlock Text="Severity" Style="{StaticResource SectionLabelTextStyle}"/>
            <ComboBox x:Name="SeverityComboBox" Height="40" Margin="0,5,0,25">
                <ComboBoxItem Content="Mild"/>
                <ComboBoxItem Content="Low"/>
                <ComboBoxItem Content="Moderate"/>
                <ComboBoxItem Content="High"/>
                <ComboBoxItem Content="Severe"/>
            </ComboBox>

            <controls:VoiceRecorderControl x:Name="SeverityVoiceRecorder"
                                           QuestionId="5"
                                           Label="Voice answer for severity"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Back"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="120"
                        Height="40"
                        Margin="0,0,10,0"
                        Click="Back_Click"/>

                <Button Content="Continue"
                        Width="140"
                        Height="40"
                        Click="Continue_Click"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</UserControl>
