<UserControl x:Class="SACA.WindowsApp.Pages.ChronicConditionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:SACA.WindowsApp.Controls">

    <Grid Background="{StaticResource AppBackgroundBrush}" Margin="40">
        <StackPanel Width="560" HorizontalAlignment="Center" VerticalAlignment="Center">

            <TextBlock Text="Do you have any chronic condition?"
                       Style="{StaticResource PageTitleTextStyle}"
                       FontSize="30"
                       TextWrapping="Wrap"
                       Margin="0,0,0,30"/>

            <StackPanel Margin="0,0,0,35">
                <CheckBox Content="Hypertension" FontSize="18" Margin="0,0,0,14" Checked="ConditionCheckBox_Checked"/>
                <CheckBox Content="Type 2 Diabetes" FontSize="18" Margin="0,0,0,14" Checked="ConditionCheckBox_Checked"/>
                <CheckBox Content="Heart Disease" FontSize="18" Margin="0,0,0,14" Checked="ConditionCheckBox_Checked"/>
                <CheckBox Content="Asthma-COPD" FontSize="18" Margin="0,0,0,14" Checked="ConditionCheckBox_Checked"/>
                <CheckBox Content="Depression Anxiety" FontSize="18" Margin="0,0,0,14" Checked="ConditionCheckBox_Checked"/>
                <CheckBox x:Name="UnknownCheckBox"
                          Content="Unknown / None"
                          FontSize="18"
                          Checked="UnknownCheckBox_Checked"/>
            </StackPanel>

            <controls:VoiceRecorderControl x:Name="VoiceRecorder"
                                           QuestionId="8"
                                           Label="Voice answer for chronic conditions"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Back"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="120"
                        Height="40"
                        Margin="0,0,10,0"
                        Click="Back_Click"/>

                <Button Content="Continue"
                        Width="140"
                        Height="40"
                        Click="Continue_Click"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</UserControl>
