<UserControl x:Class="SACA.WindowsApp.Pages.DurationPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:SACA.WindowsApp.Controls"
             xmlns:services="clr-namespace:SACA.WindowsApp.Services">

    <UserControl.Resources>
        <Style x:Key="SelectionCardRadioStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource BodyTextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Card"
                                Background="{StaticResource InputBackgroundBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="2"
                                CornerRadius="8"
                                Padding="18"
                                MinHeight="72">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Card" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="{StaticResource SelectedBackgroundBrush}"/>
                                <Setter TargetName="Card" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}" Margin="40">
        <StackPanel Width="520" HorizontalAlignment="Center" VerticalAlignment="Center">

            <Grid Width="520" Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{services:Loc duration_title}"
                           Grid.Column="0"
                           Style="{StaticResource PageTitleTextStyle}"
                           FontSize="30"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           VerticalAlignment="Center"/>
                <controls:SpeakerButtonControl Grid.Column="1"
                                               TextKey="speak_duration"/>
            </Grid>

            <StackPanel Margin="0,0,0,24">
                <RadioButton x:Name="LessThanDayRadioButton"
                             Content="{services:Loc duration_less_day}"
                             GroupName="Duration"
                             Tag="Less than a day"
                             FontSize="18"
                             Style="{StaticResource SelectionCardRadioStyle}"/>
                <RadioButton x:Name="MoreThanDayRadioButton"
                             Content="{services:Loc duration_more_day}"
                             GroupName="Duration"
                             Tag="More than a day"
                             FontSize="18"
                             Style="{StaticResource SelectionCardRadioStyle}"/>
                <RadioButton x:Name="UnknownRadioButton"
                             Content="{services:Loc unknown}"
                             GroupName="Duration"
                             Tag="Unknown"
                             FontSize="18"
                             Style="{StaticResource SelectionCardRadioStyle}"/>
            </StackPanel>

            <controls:VoiceRecorderControl x:Name="VoiceRecorder"
                                           QuestionId="6"
                                           Label="{services:Loc voice_duration}"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{services:Loc back}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="120"
                        Height="40"
                        Margin="0,0,10,0"
                        Click="Back_Click"/>

                <Button Content="{services:Loc continue}"
                        Width="140"
                        Height="40"
                        Click="Continue_Click"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</UserControl>
