<UserControl x:Class="SACA.WindowsApp.Pages.DurationPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#FFF8F1" Margin="40">
        <StackPanel Width="520" HorizontalAlignment="Center" VerticalAlignment="Center">

            <TextBlock Text="Duration of Symptoms"
                       FontSize="30"
                       FontWeight="Bold"
                       TextAlignment="Center"
                       Margin="0,0,0,30"/>

            <ComboBox x:Name="DurationComboBox"
                      Height="45"
                      Margin="0,0,0,30">
                <ComboBoxItem Content="Just began"/>
                <ComboBoxItem Content="A couple days"/>
                <ComboBoxItem Content="More than a week"/>
                <ComboBoxItem Content="Unknown"/>
            </ComboBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Back"
                        Width="120"
                        Height="40"
                        Margin="0,0,10,0"
                        Click="Back_Click"/>

                <Button Content="Assess"
                        Width="140"
                        Height="40"
                        Click="Assess_Click"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</UserControl>