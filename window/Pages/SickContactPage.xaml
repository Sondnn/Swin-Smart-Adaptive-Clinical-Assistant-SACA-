<UserControl x:Class="SACA.WindowsApp.Pages.SickContactPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:SACA.WindowsApp.Controls">

    <Grid Background="{StaticResource AppBackgroundBrush}" Margin="40">
        <StackPanel Width="620" HorizontalAlignment="Center" VerticalAlignment="Center">

            <TextBlock Text="Have you been in contact with anyone who is sick recently?"
                       Style="{StaticResource PageTitleTextStyle}"
                       FontSize="30"
                       TextWrapping="Wrap"
                       Margin="0,0,0,30"/>

            <StackPanel Margin="0,0,0,35">
                <RadioButton x:Name="YesRadioButton"
                             Content="Yes"
                             GroupName="SickContact"
                             FontSize="18"
                             Margin="0,0,0,16"/>
                <RadioButton x:Name="NoRadioButton"
                             Content="No"
                             GroupName="SickContact"
                             FontSize="18"
                             Margin="0,0,0,16"/>
                <RadioButton x:Name="UnknownRadioButton"
                             Content="Unknown"
                             GroupName="SickContact"
                             FontSize="18"/>
            </StackPanel>

            <controls:VoiceRecorderControl x:Name="VoiceRecorder"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Back"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="120"
                        Height="40"
                        Margin="0,0,10,0"
                        Click="Back_Click"/>

                <Button Content="Assess"
                        Width="140"
                        Height="40"
                        Background="{StaticResource AccentBrush}"
                        BorderBrush="{StaticResource AccentBrush}"
                        Click="Assess_Click"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</UserControl>
