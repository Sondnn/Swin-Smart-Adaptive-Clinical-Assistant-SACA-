<UserControl x:Class="SACA.WindowsApp.Pages.SeverityPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:SACA.WindowsApp.Controls"
             xmlns:services="clr-namespace:SACA.WindowsApp.Services">

    <UserControl.Resources>
        <Style x:Key="SeverityCardRadioStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource BodyTextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Card"
                                Background="{StaticResource InputBackgroundBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="2"
                                CornerRadius="8"
                                Padding="18"
                                MinHeight="92">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Card" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="{StaticResource SelectedBackgroundBrush}"/>
                                <Setter TargetName="Card" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}" Margin="40">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Width="560" HorizontalAlignment="Center">

                <Grid Width="560" Margin="0,0,0,26">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{services:Loc severity_title}"
                               Grid.Column="0"
                               Style="{StaticResource PageTitleTextStyle}"
                               FontSize="30"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               VerticalAlignment="Center"/>
                    <controls:SpeakerButtonControl Grid.Column="1"
                                                   TextKey="speak_severity"/>
                </Grid>

                <StackPanel Margin="0,0,0,18">
                    <RadioButton x:Name="MildRadioButton"
                                 GroupName="Severity"
                                 Tag="Mild"
                                 Style="{StaticResource SeverityCardRadioStyle}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="/Assets/Icons/ic_severity_mild.png" Width="52" Height="52" Stretch="Uniform" Margin="0,0,18,0"/>
                            <TextBlock Text="{services:Loc severity_mild}" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="LowRadioButton"
                                 GroupName="Severity"
                                 Tag="Low"
                                 Style="{StaticResource SeverityCardRadioStyle}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="/Assets/Icons/ic_serverity_low.png" Width="52" Height="52" Stretch="Uniform" Margin="0,0,18,0"/>
                            <TextBlock Text="{services:Loc severity_low}" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="ModerateRadioButton"
                                 GroupName="Severity"
                                 Tag="Moderate"
                                 Style="{StaticResource SeverityCardRadioStyle}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="/Assets/Icons/ic_severity_moderate.png" Width="52" Height="52" Stretch="Uniform" Margin="0,0,18,0"/>
                            <TextBlock Text="{services:Loc severity_moderate}" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="HighRadioButton"
                                 GroupName="Severity"
                                 Tag="High"
                                 Style="{StaticResource SeverityCardRadioStyle}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="/Assets/Icons/ic_severity_high.png" Width="52" Height="52" Stretch="Uniform" Margin="0,0,18,0"/>
                            <TextBlock Text="{services:Loc severity_high}" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="SevereRadioButton"
                                 GroupName="Severity"
                                 Tag="Severe"
                                 Style="{StaticResource SeverityCardRadioStyle}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="/Assets/Icons/ic_severity_severe.png" Width="52" Height="52" Stretch="Uniform" Margin="0,0,18,0"/>
                            <TextBlock Text="{services:Loc severity_severe}" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>

                <controls:VoiceRecorderControl x:Name="VoiceRecorder"
                                               QuestionId="5"
                                               Label="{services:Loc voice_severity}"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{services:Loc back}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="120"
                            Height="40"
                            Margin="0,0,10,0"
                            Click="Back_Click"/>

                    <Button Content="{services:Loc continue}"
                            Width="140"
                            Height="40"
                            Click="Continue_Click"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
